-- === [ 2. LOGIC: PERSISTENT FLING (เกาะจนกว่าจะหายไป) ] ===
local function doLockFling()
    local targetPlr = Players:FindFirstChild(targetName)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if targetPlr and targetPlr.Character and hrp then
        local tHRP = targetPlr.Character:FindFirstChild("HumanoidRootPart")
        if tHRP then
            local lastPos = hrp.CFrame
            local startTime = tick()
            
            -- วนลูปจนกว่าจะปลิวไกลเกิน 150 เมตร หรือผ่านไปเกิน 4 วินาที (กันบัค)
            while targetPlr.Character and tHRP.Parent and (tHRP.Position - lastPos.Position).Magnitude < 150 do
                RunService.Heartbeat:Wait()
                
                -- ทำให้ตัวเราหมุนเป็นพายุล่องหน
                hrp.Velocity = Vector3.new(0, 5000, 0)
                hrp.RotVelocity = Vector3.new(0, 5000, 0)
                
                -- วาร์ปไปเกาะที่เป้าหมาย (สุ่มตำแหน่งรอบๆ เพื่อเพิ่มแรงปะทะ)
                hrp.CFrame = tHRP.CFrame * CFrame.Angles(math.rad(math.random(0,360)), math.rad(math.random(0,360)), 0)
                
                -- ส่งแรงดีดเป้าหมายอย่างต่อเนื่อง
                tHRP.Velocity = Vector3.new(math.random(-100,100), 2000, math.random(-100,100))
                
                -- ตัดจบถ้าใช้เวลานานเกินไป
                if tick() - startTime > 4 then break end
            end
            
            -- วาร์ปกลับจุดเดิม
            hrp.CFrame = lastPos
            hrp.Velocity = Vector3.new(0,0,0)
            hrp.RotVelocity = Vector3.new(0,0,0)
        end
    end
end

FlingBtn.MouseButton1Click:Connect(doLockFling)

-- === [ 3. ระบบบินสมบูรณ์แบบ ] ===
local bv, bg = Instance.new("BodyVelocity"), Instance.new("BodyGyro")
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if flyEnabled and hum and hrp and hum.Sit then
        bv.Parent, bg.Parent = hrp, hrp
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.CFrame = workspace.CurrentCamera.CFrame
        local camCF = workspace.CurrentCamera.CFrame
        local dir = Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + camCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - camCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - camCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + camCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0, 1, 0) end
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.new(0, 0, 0)
    else
        bv.Parent, bg.Parent = nil, nil
    end
end)

FlyBtn.MouseButton1Click:Connect(function()
    flyEnabled = not flyEnabled
    FlyBtn.Text = flyEnabled and "ระบบบินตอนนั่ง: ON" or "ระบบบินตอนนั่ง: OFF"
    FlyBtn.BackgroundColor3 = flyEnabled and Color3.fromRGB(0, 150, 200) or Color3.fromRGB(70, 70, 70)
end)
